[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[requires]
python_version = "3.9"

[packages]
httpx = "*"

[dev-packages]
flake8 = "*"
black = "==20.8b1"
wemake-python-styleguide = "*"
mypy = "*"

[scripts]
main = "python main.py"
flake8 = "flake8 . --count --statistics --show-source"
black = "black -l 120 ."
mypy = "mypy --strict ."
